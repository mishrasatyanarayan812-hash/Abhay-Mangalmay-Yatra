<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modern Cricket - Made by Abhay Mishra</title>
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        background: linear-gradient(to bottom, #87CEEB, #228B22);
        font-family: 'Arial', sans-serif;
        overflow: hidden;
    }
    canvas {
        border: 4px solid #333;
        background: #32CD32;
        box-shadow: 0 0 20px rgba(0,0,0,0.4);
    }
    #ui {
        position: absolute;
        top: 10px;
        width: 400px;
        text-align: center;
        color: white;
        font-weight: bold;
        text-shadow: 2px 2px 3px #000;
    }
    #scoreBoard {
        position: absolute;
        bottom: 10px;
        left: 10px;
        color: white;
        font-size: 20px;
        font-weight: bold;
        text-shadow: 2px 2px 3px #000;
    }
    #legend {
        position: absolute;
        right: 10px;
        top: 50px;
        color: white;
        font-size: 14px;
        background: rgba(0,0,0,0.6);
        padding: 10px;
        border-radius: 8px;
    }
    #startScreen, #gameOverScreen {
        position: absolute;
        text-align: center;
        color: white;
        background: rgba(0,0,0,0.8);
        padding: 30px;
        border-radius: 15px;
        width: 350px;
    }
    #startScreen h1 { font-size: 36px; color: #FFD700; margin-bottom: 10px; }
    #gameOverScreen h1 { font-size: 36px; color: red; margin-bottom: 10px; }
    .credit { font-size: 16px; color: #FFD700; margin-top: 10px; }
    button {
        margin-top: 15px;
        padding: 12px 25px;
        font-size: 20px;
        background: #FF4500;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
    }
    button:hover { background: #FF6347; }
    #celebration {
        position: absolute;
        font-size: 40px;
        color: gold;
        display: none;
        animation: party 1s infinite;
    }
    @keyframes party {
        0% { transform: scale(1); }
        50% { transform: scale(1.3); }
        100% { transform: scale(1); }
    }
</style>
</head>
<body>

<div id="ui">Runs: <span id="runs">0</span> | Balls: <span id="balls">0</span> | RR: <span id="rr">0.00</span></div>
<div id="scoreBoard">Total: 0</div>
<div id="legend">
    <b>Target Zones:</b><br>
    ⬆️ Top = 6 Runs<br>
    ⬇️ Bottom = 1 Run<br>
    ⬇️+1 = 2 Runs<br>
    ⬇️+2 = 3 Runs<br>
    ⬇️+3 = 4 Runs<br>
    Other = OUT
</div>

<div id="startScreen">
    <h1>MODERN CRICKET</h1>
    <p>Click to Hit the Ball</p>
    <p>Hit the zones to score!</p>
    <p>Miss the stump = OUT</p>
    <button onclick="startGame()">START GAME</button>
    <p class="credit">Made by Abhay Mishra</p>
</div>

<div id="gameOverScreen" style="display:none;">
    <h1>GAME OVER</h1>
    <p>Total Runs: <span id="finalRuns">0</span></p>
    <p>Run Rate: <span id="finalRR">0.00</span></p>
    <button onclick="restartGame()">RESTART</button>
    <p class="credit">Made by Abhay Mishra</p>
</div>

<div id="celebration">🎉 PARTY TIME! 50 RUNS! 🎉</div>

<canvas id="gameCanvas" width="400" height="600"></canvas>

<script>
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');

let ball, batX, ballComing, gameRunning, runs, balls, stumpX, stumpY;

// Zones
const zones = [
    {y: 0, h: 80, run: 6, color: '#FF0000'},   // 6
    {y: 80, h: 520, run: 'OUT', color: '#000'}, // OUT
    {y: 520, h: 20, run: 4, color: '#0000FF'},  // 4
    {y: 540, h: 20, run: 3, color: '#008000'},  // 3
    {y: 560, h: 20, run: 2, color: '#FFA500'},  // 2
    {y: 580, h: 20, run: 1, color: '#FFFF00'}   // 1
];

function startGame() {
    document.getElementById('startScreen').style.display = 'none';
    document.getElementById('gameOverScreen').style.display = 'none';
    document.getElementById('celebration').style.display = 'none';

    batX = 200;
    runs = 0;
    balls = 0;
    gameRunning = true;
    stumpX = 190;
    stumpY = 550;
    ballComing = false;
    updateUI();
    gameLoop();
    setTimeout(throwBall, 1000);
}

function restartGame() {
    startGame();
}

